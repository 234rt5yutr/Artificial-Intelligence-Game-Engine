{
  "name": "artificial-intelligence-game-engine",
  "version-string": "1.0.0",
  "description": "Custom Multiplayer 3D Game Engine",
  "dependencies": [
    "spdlog",
    "glm",
    "tracy",
    {
      "name": "sdl3",
      "features": ["vulkan"]
    },
    "vulkan",
    "vulkan-memory-allocator",
    "shaderc",
    "cgltf",
    "entt",
    "joltphysics",
    "gamenetworkingsockets",
    "cpp-httplib",
    "nlohmann-json",
    "lua",
    "miniaudio",
    {
      "name": "imgui",
      "features": ["vulkan-binding", "sdl3-binding", "docking-experimental"]
    },
    "stb",
    "recastnavigation"
  ]
}
